@model IEnumerable<SLMS.WebApp.Models.CustodyHistoryReportViewModel>

    @{
    ViewData["Title"] = "Custody History";

    var totalTransactions = Model.Count();

    var totalIssued =
        Model.Count(x => x.Action == "Issued");

    var totalReturned =
        Model.Count(x => x.Action == "Returned");

    var currentlyIssued =
        Model.Count(x => x.Action == "Issued");

    var totalResources =
        Model.Select(x => x.ResourceTitle)
             .Distinct()
             .Count();

    var totalEmployees =
        Model.Select(x => x.EmployeeName)
             .Distinct()
             .Count();
}


@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<h2 class="mb-4">Custody History</h2>

<!-- Summary Cards -->

<div class="row mb-4">

    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Total Transactions</h6>
                <h3 class="text-primary">@totalTransactions</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Issued</h6>
                <h3 class="text-primary">@totalIssued</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Returned</h6>
                <h3 class="text-success">@totalReturned</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Currently Issued</h6>
                <h3 class="text-warning">@currentlyIssued</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Resources</h6>
                <h3 class="text-info">@totalResources</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h6>Employees</h6>
                <h3 class="text-dark">
                    @totalEmployees
                </h3>
            </div>
        </div>
    </div>
</div>

<!-- Timeline -->

<h4 class="mb-3">Transaction Timeline</h4>

@foreach (var item in Model.Take(10))
{
    <div class="card mb-3 shadow-sm border-start border-4 @(item.Action == "Issued" ? "border-primary" : "border-success")">

        <div class="card-body">

            @if (item.Action == "Issued")
            {
                <p class="mb-2">

                    <span class="badge bg-primary">
                        📘 ISSUED
                    </span>

                    <strong>"@item.ResourceTitle"</strong>

                    was issued to

                    <strong>@item.EmployeeName</strong>

                </p>

                <small class="text-muted">
                    Department: @item.DepartmentName
                </small>

                <br />

                <small class="text-secondary">
                    Issue Date:
                    @item.IssueDate.ToString("dd-MMM-yyyy")
                </small>
            }
            else
            {
                <p class="mb-2">

                    <span class="badge bg-success">
                        📗 RETURNED
                    </span>

                    <strong>"@item.ResourceTitle"</strong>

                    was returned by

                    <strong>@item.EmployeeName</strong>

                </p>

                <small class="text-muted">
                    Department: @item.DepartmentName
                </small>

                <br />

                <small class="text-secondary">
                    Return Date:
                    @(item.ReturnDate?.ToString("dd-MMM-yyyy") ?? "-")
                </small>
            }

        </div>

    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        No Custody Records Found.
    </div>
}
else
{
    <div class="card shadow-sm">

        <div class="card-body">

            <table class="table table-bordered table-striped table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Issue Date</th>
                        <th>Return Date</th>
                        <th>Resource</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Action</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.IssueDate.ToString("dd-MMM-yyyy")
                            </td>

                            <td>
                                @(item.ReturnDate?.ToString("dd-MMM-yyyy") ?? "-")
                            </td>

                            <td>@item.ResourceTitle</td>

                            <td>@item.EmployeeName</td>

                            <td>@item.DepartmentName</td>

                            <td>
                                @if (item.Action == "Issued")
                                {
                                    <span class="badge bg-primary">
                                        Issued
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Returned
                                    </span>
                                }
                            </td>

                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-warning text-dark">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Closed
                                    </span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}