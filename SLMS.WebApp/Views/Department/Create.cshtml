@model SLMS.WebApp.Models.DepartmentViewModel

@{
    ViewData["Title"] = "Create Department";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">

        <li class="breadcrumb-item">
            <a asp-controller="Home"
               asp-action="Index">
                Dashboard
            </a>
        </li>

        <li class="breadcrumb-item">
            <a asp-controller="Department"
               asp-action="Index">
                Departments
            </a>
        </li>

        <li class="breadcrumb-item active">
            Create Department
        </li>

    </ol>
</nav>

<div class="card shadow-sm">

    <div class="card-body">

        <h2>Create Department</h2>

        <p class="text-danger fw-bold">
            * Indicates required fields
        </p>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="mb-3">

                <label asp-for="DepartmentCode"
                       class="form-label">
                    Department Code
                    <span class="text-danger">*</span>
                </label>

                <input asp-for="DepartmentCode"
                       class="form-control"
                       tabindex="1" />

                <span asp-validation-for="DepartmentCode"
                      class="text-danger"></span>

            </div>

            <div class="mb-3">

                <label asp-for="DepartmentName"
                       class="form-label">
                    Department Name
                    <span class="text-danger">*</span>
                </label>

                <input asp-for="DepartmentName"
                       class="form-control"
                       tabindex="2" />

                <span asp-validation-for="DepartmentName"
                      class="text-danger"></span>

            </div>

            <div class="mb-3">

                <label asp-for="Description"
                       class="form-label">
                    Description
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="3"
                          tabindex="3"></textarea>

                <span asp-validation-for="Description"
                      class="text-danger"></span>

            </div>

            <button type="submit"
                    class="btn btn-success"
                    tabindex="4">
                Save
            </button>

            <a asp-action="Index"
               class="btn btn-secondary"
               tabindex="5">
                Cancel
            </a>

        </form>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}