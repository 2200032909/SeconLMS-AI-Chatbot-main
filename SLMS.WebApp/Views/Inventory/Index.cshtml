@model SLMS.WebApp.Models.Inventory.InventoryPagedViewModel

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="card shadow-sm">

    ```
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h3>Inventory Management</h3>

            <a asp-action="Create"
               class="btn btn-primary">
                Add Inventory Item
            </a>

        </div>

        <!-- Search -->

        <form method="get" class="mb-3">

            <div class="input-group">

                <input type="text"
                       name="searchTerm"
                       class="form-control"
                       placeholder="Search Inventory..."
                       value="@Model.SearchTerm" />

                <button type="submit"
                        class="btn btn-primary">
                    Search
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Clear
                </a>

            </div>

        </form>

        <!-- Sorting -->

        <form method="get" class="row mb-3">

            <div class="col-md-4">

                <select name="sortBy"
                        class="form-select">

                    <option value="">
                        Sort By
                    </option>

                    <option value="AccessionNumber">
                        Accession Number
                    </option>

                    <option value="InventoryNumber">
                        Inventory Number
                    </option>

                    <option value="ShelfNumber">
                        Shelf Number
                    </option>

                    <option value="Price">
                        Price
                    </option>

                </select>

            </div>

            <div class="col-md-3">

                <select name="descending"
                        class="form-select">

                    <option value="false">
                        Ascending
                    </option>

                    <option value="true">
                        Descending
                    </option>

                </select>

            </div>

            <div class="col-md-2">

                <button type="submit"
                        class="btn btn-primary">
                    Sort
                </button>

            </div>

        </form>

        <!-- Inventory Table -->

        <table class="table table-bordered table-striped table-hover">

            <thead>

                <tr>
                    <th>Accession Number</th>
                    <th>Inventory Number</th>
                    <th>Shelf Number</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Items)
                {
                    <tr>

                        <td>@item.AccessionNumber</td>

                        <td>@item.InventoryNumber</td>

                        <td>@item.ShelfNumber</td>

                        <td>@item.Price</td>

                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactive
                                </span>
                            }
                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                                Details
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this inventory item?');">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <!-- Pagination -->

        <nav>

            <ul class="pagination">

                @if (Model.Page > 1)
                {
                    <li class="page-item">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.Page - 1)">
                            Previous
                        </a>

                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                            @i
                        </a>

                    </li>
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <li class="page-item">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.Page + 1)">
                            Next
                        </a>

                    </li>
                }

            </ul>

        </nav>

    </div>


</div>
