@model List<SLMS.WebApp.Models.CategoryViewModel>

@{
    ViewData["Title"] = "Category Management";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-3">
        <li class="breadcrumb-item">
            <a asp-controller="Home"
               asp-action="Index">
                Dashboard
            </a>
        </li>

        <li class="breadcrumb-item active"
            aria-current="page">
            Categories
        </li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="d-flex justify-content-between mb-3">

            <h3>Category Management</h3>

            <a asp-action="Create"
               class="btn btn-primary">
                Add Category
            </a>

        </div>

        <!-- Search + Refresh + Sort -->
        <div class="row mb-3 align-items-center">

            <div class="col-md-7">

                <input type="text"
                       id="searchBox"
                       class="form-control"
                       placeholder="🔍 Search Category..."
                       onkeyup="searchCategory()" />

            </div>

            <div class="col-md-2">

                <button type="button"
                        class="btn btn-outline-secondary w-100"
                        onclick="refreshSearch()">

                    🔄 Refresh

                </button>

            </div>

            <div class="col-md-3 text-end">

                <div class="dropdown">

                    <button class="btn btn-outline-primary dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown">

                        Sort By

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <a class="dropdown-item"
                               href="#"
                               onclick="sortCategory('asc')">

                                A - Z

                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               href="#"
                               onclick="sortCategory('desc')">

                                Z - A

                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <table class="table table-bordered table-striped table-hover">

            <thead>

                <tr>

                    <th>
                        Category Name
                    </th>

                    <th>
                        Description
                    </th>

                    <th width="220">
                        Actions
                    </th>

                </tr>

            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.Name</td>

                            <td>@item.Description</td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a href="#"
                                   class="btn btn-danger btn-sm"
                                   onclick="deleteCategory(@item.Id)">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="3"
                            class="text-center">

                            No Categories Found

                        </td>

                    </tr>
                }

            </tbody>

        </table>
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">
                            @i
                        </a>

                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>

            </ul>
        </nav>


    </div>
</div>

@section Scripts
{
    <script>
                function deleteCategory(id)
        {
            Swal.fire({
                title: 'Delete Category?',
                text: 'You will not be able to recover this record!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete'
            }).then((result) => {

                if (result.isConfirmed)
                {
                    window.location.href =
                        '/Category/Delete/' + id;
                }

            });
        }

        function searchCategory()
        {
            let input =
                document.getElementById("searchBox")
                    .value
                    .toLowerCase();

            let rows =
                document.querySelectorAll("tbody tr");

            rows.forEach(row =>
            {
                let category =
                    row.cells[0]?.innerText.toLowerCase();

                let description =
                    row.cells[1]?.innerText.toLowerCase();

                if (
                    (category && category.includes(input)) ||
                    (description && description.includes(input))
                )
                {
                    row.style.display = "";
                }
                else
                {
                    row.style.display = "none";
                }
            });
        }

        function refreshSearch()
        {
            document.getElementById("searchBox").value = "";

            let rows =
                document.querySelectorAll("tbody tr");

            rows.forEach(row =>
            {
                row.style.display = "";
            });
        }

        function sortCategory(order)
        {
            let tbody =
                document.querySelector("tbody");

            let rows =
                Array.from(tbody.querySelectorAll("tr"));

            rows.sort(function (a, b)
            {
                let x =
                    a.cells[0].innerText.toLowerCase();

                let y =
                    b.cells[0].innerText.toLowerCase();

                return order === "asc"
                    ? x.localeCompare(y)
                    : y.localeCompare(x);
            });

            rows.forEach(row =>
                tbody.appendChild(row));
        }

    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["SuccessMessage"]',
                timer: 2500,
                showConfirmButton: false
            });
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["ErrorMessage"]'
            });
        </script>
    }
}