@model List<SLMS.WebApp.Models.Inventory.ShelfViewModel>

@if (TempData["SuccessMessage"] != null)
{
     <div class="d-flex justify-content-center">
        <div class="alert alert-success text-center shadow-sm w-50">
            <i class="bi bi-check-circle-fill"></i>
            @TempData["SuccessMessage"]
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="d-flex justify-content-center">
        <div class="alert alert-danger text-center shadow-sm w-50">
            @TempData["ErrorMessage"]
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">

    
    <h2 class="mb-0">Shelf Management</h2>

    <a asp-action="Create"
       class="btn btn-primary">
        Add Shelf
    </a>
    

</div>

<div class="row mb-4">

    <div class="col-md-3">

        <div class="card shadow-sm text-center">

            <div class="card-body">

                <h6 class="text-muted">
                    Total Shelves
                </h6>

                <h3>
                    @Model.Count()
                </h3>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm text-center">

            <div class="card-body">

                <h6 class="text-muted">
                    Total Capacity
                </h6>

                <h3>
                    @Model.Sum(x => x.Capacity)
                </h3>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm text-center">

            <div class="card-body">

                <h6 class="text-muted">
                    Books Stored
                </h6>

                <h3>
                    @Model.Sum(x => x.CurrentBookCount)
                </h3>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card shadow-sm text-center">

            <div class="card-body">

                <h6 class="text-muted">
                    Available Space
                </h6>

                <h3>
                    @(Model.Sum(x => x.Capacity)
                        - Model.Sum(x => x.CurrentBookCount))
                </h3>

            </div>

        </div>

    </div>

</div>

<form method="get" class="mb-4">

    
    <div class="row">

        <div class="col-md-4">

            <input type="text"
                   name="searchTerm"
                   value="@ViewBag.SearchTerm"
                   class="form-control"
                   placeholder="Search Shelf Name..." />

        </div>

        <div class="col-md-3">

            <button type="submit"
                    class="btn btn-primary">
                Search
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Clear
            </a>

        </div>

    </div>
 
</form>

<div class="card shadow-sm">

    
    <div class="card-body">

        <table class="table table-bordered table-hover mb-0">

            <thead class="table-light">

                <tr>
                    <th>Shelf Name</th>
                    <th>Capacity</th>
                    <th>Current Book Count</th>
                    <th>Remaining space</th>
                    <th style="width:220px;">Actions</th>
                </tr>

            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.ShelfName</td>

                            <td>@item.Capacity</td>

                            <td>@item.CurrentBookCount</td>
                            <td>@item.RemainingCapacity</td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm text-white"
                                   style="background-color:#1e3a5f;">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm text-white"
                                   style="background-color:#1e3a5f;">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Are you sure you want to delete this shelf?');">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="4"
                            class="text-center text-muted">
                            No shelves found.
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
    

</div>
