    <!-- ================= AI Assistant ================= -->
    <!-- AI Floating Button -->
<button id="aiButton" class="btn btn-primary shadow-lg">
    🤖
</button>

<!-- AI Chat -->
<div id="aiChatBox" class="card shadow-lg">

    <!-- Header -->
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

        <div>
            <h6 class="mb-0">🤖 SECON AI Assistant</h6>
            <small id="aiStatus">🟢 Online</small>
        </div>

        <button id="closeAI"
                class="btn btn-light btn-sm">
            ✕
        </button>

    </div>

    <!-- Quick Questions -->
    <div class="border-bottom p-2 bg-white">

        <button class="btn btn-outline-primary btn-sm quickQuestion">
            Dashboard
        </button>

        <button class="btn btn-outline-success btn-sm quickQuestion">
            Employees
        </button>

        <button class="btn btn-outline-warning btn-sm quickQuestion">
            Books
        </button>

        <button class="btn btn-outline-info btn-sm quickQuestion">
            Departments
        </button>

        <button class="btn btn-outline-danger btn-sm quickQuestion">
            Overdue
        </button>

        <button class="btn btn-outline-dark btn-sm quickQuestion">
            Recommendation
        </button>

    </div>

    <!-- Messages -->
    <div id="chatMessages">

        <div class="aiMessage">

            👋 Hello <b>@User.Identity?.Name</b>

            <br><br>

            Welcome to SECON AI.

            <br><br>

            Ask me anything about

            <br>

            📚 Books

            <br>

            👨 Employees

            <br>

            🏢 Departments

            <br>

            📊 Dashboard

            <br>

            📈 Analytics

        </div>

    </div>

    <!-- Footer -->
    <div class="card-footer bg-white">

        <div class="input-group">

            <input
                id="txtQuestion"
                type="text"
                class="form-control"
                autocomplete="off"
                placeholder="Ask anything..." />

            <button
                id="btnSend"
                class="btn btn-primary">

                Send

            </button>

        </div>

    </div>

</div>
