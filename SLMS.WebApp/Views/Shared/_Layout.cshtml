          href="~/SLMS.WebApp.styles.css"
          asp-append-version="true" />
</head>

<script>
    setTimeout(function () {

        var alerts =
            document.querySelectorAll('.alert');

        alerts.forEach(function (alert) {

            alert.style.transition = "opacity 0.5s";

            alert.style.opacity = "0";

            setTimeout(function () {
                alert.remove();
            }, 500);

        });

    }, 3000);
</script>

