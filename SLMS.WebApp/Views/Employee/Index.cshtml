@model IEnumerable<SLMS.WebApp.Models.EmployeeViewModel>

@{
    ViewData["Title"] = "Employees";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home"
               asp-action="Index">
                Dashboard
            </a>
        </li>

        <li class="breadcrumb-item active">
            Employees
        </li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card shadow-sm">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2 class="mb-0">
                Employee Management
            </h2>

            <a asp-action="Create"
               class="btn btn-success">
                + Add Employee
            </a>

        </div>

        <form asp-action="Index"
              method="get"
              class="mb-4">

            <div class="row g-3 align-items-end">

                <div class="col-md-4">
                    <label class="form-label">
                        Search Employee
                    </label>

                    <input type="text"
                           name="name"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Enter Employee Name" />
                </div>

                <div class="col-md-3">

                    <label class="form-label">
                        Department
                    </label>

                    <select name="departmentId"
                            asp-items="ViewBag.Departments"
                            class="form-select">

                        <option value="">
                            All Departments
                        </option>

                    </select>

                </div>

                <div class="col-md-5">

                    <button type="submit"
                            class="btn btn-primary">
                        Search
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        Clear
                    </a>

                </div>

            </div>

        </form>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                No Employees Found.
            </div>
        }
        else
        {
            <style>

                .employee-table tbody tr:nth-child(odd) {
                    background: #FFFBEA;
                }

                .employee-table tbody tr:nth-child(even) {
                    background: #F4F4F4;
                }

                .employee-table tbody tr:hover {
                    background: #D6EAF8;
                }

            </style>

            <div class="table-responsive">

                <table class="table table-bordered employee-table">

                    <thead class="table-dark">

                        <tr>

                            <th>Employee No</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Department Id</th>
                            <th>Designation</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th style="width:150px;">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.EmployeeNumber</td>

                                <td>@item.FullName</td>

                                <td>@item.DepartmentName</td>

                                <td>@item.DepartmentId</td>

                                <td>@item.Designation</td>

                                <td>@item.Email</td>

                                <td>@item.Phone</td>

                                <td>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          style="display:inline;">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this employee?');">
                                            Delete
                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <nav class="mt-4">

                <ul class="pagination justify-content-center">

                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-departmentId="@Context.Request.Query["departmentId"]"
                           asp-route-name="@Context.Request.Query["name"]">

                            Previous

                        </a>

                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-departmentId="@Context.Request.Query["departmentId"]"
                               asp-route-name="@Context.Request.Query["name"]">

                                @i

                            </a>

                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-departmentId="@Context.Request.Query["departmentId"]"
                           asp-route-name="@Context.Request.Query["name"]">

                            Next

                        </a>

                    </li>

                </ul>

            </nav>

        }

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}