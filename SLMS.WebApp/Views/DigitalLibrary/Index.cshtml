@model List<SLMS.WebApp.Models.DigitalLibrary.DigitalContentViewModel>

@using SLMS.WebApp.Models.DigitalLibrary

@{
    var requests =
        ViewBag.Requests as List<RequestStatusViewModel>;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@{
    ViewData["Title"] = "Digital Library";
}


<div class="card shadow-sm">

    <div class="card-body">

        <div class="d-flex justify-content-between mb-3">

            <h3 class="mb-0">Digital Library</h3>

            <p class="text-muted">
                Browse available digital content and request access.
            </p>

        </div>

        <div class="mb-3">

            <input type="text"
                   id="searchBox"
                   class="form-control"
                   placeholder="Search by title, category or description..." />

        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">

            <a asp-action="Policies"
               class="btn btn-info">

                Policies

            </a>

            <a asp-action="Downloads"
               class="btn btn-success">

                Download History

            </a>

        </div>

        <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover">

            <thead>

                <tr>

                    <th>Title</th>

                    <th>Category</th>

                    <th>Description</th>

                    <th>Status</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody id="contentTable">

                    @foreach (var item in Model)
                    {
                        var request =
                        requests?
                        .Where(x => x.DigitalContentId == item.Id)
                        .OrderByDescending(x => x.Id)
                        .FirstOrDefault();

                        <tr>

                            <td>@item.Title</td>

                            <td>@item.Category</td>

                            <td>@item.Description</td>

                            <td>

                                @if (request == null)
                                {
                                    <span class="badge bg-secondary">
                                        Not Requested
                                    </span>
                                }
                                else if (request.ApprovalStatus == "Pending")
                                {
                                    <span class="badge bg-warning">
                                        Pending
                                    </span>
                                }
                                else if (request.ApprovalStatus == "Approved")
                                {
                                    <span class="badge bg-success">
                                        Approved
                                    </span>
                                }
                                else if (request.ApprovalStatus == "Rejected")
                                {
                                    <span class="badge bg-danger">
                                        Rejected
                                    </span>
                                }

                            </td>

                            <td>

                                @if (request == null)
                                {
                                    <a asp-action="Request"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary btn-sm">

                                        Request Access

                                    </a>
                                }
                                else if (request.ApprovalStatus == "Pending")
                                {
                                    <button class="btn btn-secondary btn-sm"
                                            disabled>

                                        Request Sent

                                    </button>
                                }
                                else if (request.ApprovalStatus == "Approved")
                                {
                                    <a asp-action="ReadContent"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm">

                                        Read

                                    </a>

                                    <a asp-action="Download"
                                       asp-route-id="@item.Id"
                                       class="btn btn-success btn-sm">

                                        Download

                                    </a>
                                }
                                else if (request.ApprovalStatus == "Rejected")
                                {
                                    <a asp-action="Request"
                                       asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm">

                                        Request Again

                                    </a>
                                }

                            </td>

                        </tr>
                    }

            </tbody>

        </table>
        </div>

    </div>

</div>

@section Scripts {

    <script>

        document
            .getElementById("searchBox")
            .addEventListener("keyup", function () {

                let filter =
                    this.value.toLowerCase();

                let rows =
                    document.querySelectorAll(
                        "#contentTable tr");

                rows.forEach(function (row) {

                    let text =
                        row.innerText.toLowerCase();

                    row.style.display =
                        text.includes(filter)
                            ? ""
                            : "none";
                });
            });

    </script>

}