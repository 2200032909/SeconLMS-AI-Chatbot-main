@model List<SLMS.WebApp.Models.DigitalLibrary.PolicyViewModel>


<div class="card shadow-sm">

 <div class="card-body">

        <div class="d-flex justify-content-between">
            <h2>Manage Policies</h2>

            <a asp-action="CreatePolicy"
             class="btn btn-success mb-3">

                Add Policy

            </a>
        </div>

<table class="table table-bordered">

    <thead>

        <tr>

            <th>Title</th>

            <th>Actions</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Title</td>

                <td>

                    <a asp-action="EditPolicy"
                       asp-route-id="@item.Id"
                       class="btn btn-warning">

                        Edit

                    </a>

                    <a asp-action="DeletePolicy"
                       asp-route-id="@item.Id"
                       class="btn btn-danger">

                        Delete

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>
</div>
</div>