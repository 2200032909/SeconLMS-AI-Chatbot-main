@model SLMS.WebApp.Models.DigitalLibrary.AdminPolicyViewModel

<form asp-action="EditPolicy"
      method="post">

    <input asp-for="Id"
           type="hidden" />

    <div class="mb-3">

        <label>Title</label>

        <input asp-for="PolicyTitle"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label>Content</label>

        <textarea asp-for="PolicyContent"
                  class="form-control">
        </textarea>

    </div>

    <button class="btn btn-success">

        Update

    </button>

</form>